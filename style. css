
body {
  margin: 0;
  background: #050505;
  color: white;
  font-family: Arial, sans-serif;
  padding: 16px;
}

.card {
  background: #111;
  border-radius: 18px;
  padding: 16px;
  max-width: 900px;
  margin: auto;
  box-shadow: 0 0 20px rgba(0,0,0,0.5);
}

h1 {
  margin: 0;
  font-size: 22px;
  font-weight: bold;
}

.subtitle {
  color: #aaa;
  margin-top: 4px;
}

canvas {
  margin-top: 16px;
  width: 100%;
  height: 360px;
}

#readout {
  margin-top: 12px;
  background: #1b1b1b;
  padding: 12px;
  border-radius: 12px;
  color: #ddd;
}
